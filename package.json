{
  "name": "@zimetuer/startserver",
  "version": "1.0.1",
  "description": "Kreator konfiguracji serwera Minecraft TUI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "startserver": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/plugin/",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "build:plugin": "node scripts/build-plugin.mjs",
    "build": "node build.mjs && node scripts/build-plugin.mjs",
    "start": "node build.mjs && node scripts/build-plugin.mjs && node dist/index.js",
    "postinstall": "node scripts/download-plugin.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "minecraft",
    "server",
    "wizard",
    "cli",
    "tui",
    "setup"
  ],
  "author": "zimetuer",
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.3.0",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  }
}
